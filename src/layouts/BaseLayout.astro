---
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import { ui } from '~/i18n/ui';

const t = ui.uk;
const tEn = ui.en;
const base = import.meta.env.BASE_URL;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();

// JSON values usable from inline client script (must be safe to embed)
const titles = JSON.stringify({ uk: t.meta.title, en: tEn.meta.title });
const descriptions = JSON.stringify({ uk: t.meta.description, en: tEn.meta.description });
---
<!doctype html>
<html lang="uk" data-lang="uk" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" type="image/png" sizes="192x192" href={`${base}aok-favicon-192.png`} />
    <link rel="icon" type="image/png" sizes="512x512" href={`${base}aok-favicon-512.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}apple-touch-icon.png`} />
    <link rel="canonical" href={canonical} />

    <title>{t.meta.title}</title>
    <meta name="description" content={t.meta.description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={t.meta.title} />
    <meta property="og:description" content={t.meta.description} />
    <meta property="og:image" content={`${base}aok-favicon-512.png`} />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content={t.meta.ogAlt} />
    <meta property="og:locale" content="uk_UA" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Geist:wght@300;400;500;600&display=swap"
    />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Асоціація Охоронних Компаній',
      alternateName: ['АОК', 'Security Companies Association of Ukraine', 'SCAU'],
      url: canonical,
      logo: `${base}aok-favicon-512.png`,
      email: 'pubAGC@ukr.net',
      telephone: '+380756290787',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'вул. Шовковична, 5, оф. 2',
        addressLocality: 'Київ',
        postalCode: '01021',
        addressCountry: 'UA',
      },
      areaServed: 'UA',
    })} />

    <!-- pre-render lang init (no FOUC) -->
    <script is:inline define:vars={{ titles, descriptions }}>
      (function () {
        try {
          const saved = localStorage.getItem('aok-lang');
          const lang = saved === 'en' ? 'en' : 'uk';
          const html = document.documentElement;
          html.setAttribute('data-lang', lang);
          html.setAttribute('lang', lang);
          if (lang !== 'uk') {
            const t = JSON.parse(titles);
            const d = JSON.parse(descriptions);
            document.title = t[lang] || t.uk;
            const meta = document.querySelector('meta[name="description"]');
            if (meta) meta.setAttribute('content', d[lang] || d.uk);
          }
        } catch (e) { /* noop */ }
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[200] focus:bg-gold-500 focus:text-ink-950 focus:px-4 focus:py-2">
      <span data-lang-content="uk">Перейти до контенту</span>
      <span data-lang-content="en">Skip to content</span>
    </a>

    <div data-lang-content="uk">
      <Header lang="uk" />
    </div>
    <div data-lang-content="en">
      <Header lang="en" />
    </div>

    <main id="main">
      <slot />
    </main>

    <div data-lang-content="uk">
      <Footer lang="uk" />
    </div>
    <div data-lang-content="en">
      <Footer lang="en" />
    </div>

    <script is:inline define:vars={{ titles, descriptions }}>
      // intersection-observer reveal
      (function () {
        const els = document.querySelectorAll('.reveal');
        if ('IntersectionObserver' in window && els.length) {
          const io = new IntersectionObserver(function (entries) {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
          els.forEach(function (el) { io.observe(el); });
        } else {
          els.forEach(function (el) { el.classList.add('is-visible'); });
        }
      })();

      // language toggle
      (function () {
        const t = JSON.parse(titles);
        const d = JSON.parse(descriptions);
        function setLang(lang) {
          const html = document.documentElement;
          html.setAttribute('data-lang', lang);
          html.setAttribute('lang', lang);
          try { localStorage.setItem('aok-lang', lang); } catch (e) {}
          document.title = t[lang] || t.uk;
          const meta = document.querySelector('meta[name="description"]');
          if (meta) meta.setAttribute('content', d[lang] || d.uk);
          document.querySelectorAll('[data-lang-set]').forEach(function (btn) {
            const active = btn.getAttribute('data-lang-set') === lang;
            btn.classList.toggle('is-active', active);
            btn.setAttribute('aria-pressed', String(active));
          });
        }
        // sync on load (in case storage was set)
        const initial = document.documentElement.getAttribute('data-lang') || 'uk';
        document.querySelectorAll('[data-lang-set]').forEach(function (btn) {
          const active = btn.getAttribute('data-lang-set') === initial;
          btn.classList.toggle('is-active', active);
          btn.setAttribute('aria-pressed', String(active));
          btn.addEventListener('click', function () {
            setLang(btn.getAttribute('data-lang-set'));
          });
        });
      })();
    </script>
  </body>
</html>
