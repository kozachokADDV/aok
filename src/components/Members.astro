---
import { ui, type Lang } from '~/i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = ui[lang];
---
<section id="members" class="py-24 md:py-32 relative">
  <div class="container-x">
    <header class="max-w-3xl reveal">
      <p class="eyebrow">{t.members.eyebrow}</p>
      <h2 class="mt-6 text-[clamp(2rem,4.5vw,3.75rem)] leading-[1.05]">
        {t.members.headline}
      </h2>
      <p class="mt-6 text-bone-300 leading-relaxed">{t.members.lead}</p>
    </header>

    <div class="mt-16 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-px bg-ink-700">
      {t.members.list.map((m, i) => (
        <article class="aspect-[4/5] bg-ink-900/80 hover:bg-ink-800/80 transition-colors duration-300 p-6 flex flex-col justify-between reveal" style={`--reveal-delay: ${i * 60}ms`}>
          <div class="flex items-start justify-between text-[0.6rem] tracking-[0.22em] uppercase text-bone-400">
            <span>0{i + 1}</span>
            <span>UA</span>
          </div>
          <div class="flex-1 flex items-center justify-center">
            <svg viewBox="0 0 80 90" class="w-16 h-16 opacity-70" fill="none" aria-hidden="true">
              <path d="M40 8 L70 16 L70 48 C70 64 57 78 40 84 C23 78 10 64 10 48 L10 16 Z" stroke="#C9A55C" stroke-width="1.4" fill="rgba(201,165,92,0.04)"/>
              <text x="40" y="56" text-anchor="middle" font-family="Cormorant Garamond, serif" font-size="22" fill="#C9A55C" font-style="italic">{m.name.charAt(0)}</text>
            </svg>
          </div>
          <div>
            <h3 class="font-display text-lg text-bone-100 leading-tight">{m.name}</h3>
            <p class="mt-1 text-[0.65rem] tracking-[0.18em] uppercase text-bone-400">{m.meta}</p>
          </div>
        </article>
      ))}
    </div>

    <p class="mt-8 text-xs text-bone-400 italic max-w-xl">{t.members.note}</p>
  </div>
</section>
