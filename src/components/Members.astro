---
import { ui, type Lang } from '~/i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = ui[lang];
---
<section id="members" class="py-24 md:py-32 relative overflow-hidden">
  <div class="container-x">
    <header class="max-w-3xl reveal">
      <p class="eyebrow">{t.members.eyebrow}</p>
      <h2 class="mt-6 text-[clamp(2rem,4.5vw,3.75rem)] leading-[1.05]">
        {t.members.headline}
      </h2>
      <p class="mt-6 text-bone-300 leading-relaxed" style="text-align: justify; hyphens: auto; -webkit-hyphens: auto;">{t.members.lead}</p>
    </header>

    <div class="mt-16 md:mt-20 grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
      <!-- oversize numeral anchor — 5 columns -->
      <div class="lg:col-span-5 reveal">
        <div class="flex items-baseline gap-4">
          <span class="text-[0.65rem] tracking-[0.28em] uppercase text-bone-400">{t.members.countLabel}</span>
          <span class="block flex-1 h-px bg-ink-600"></span>
        </div>
        <div class="mt-3 leading-none">
          <span class="font-display italic text-gold-500 text-[clamp(8rem,18vw,16rem)] tracking-tight" style="font-feature-settings: 'lnum';">100</span><span class="font-display text-gold-500 text-[clamp(5rem,11vw,10rem)] align-top relative -top-2">+</span>
        </div>
        <div class="mt-2 max-w-md text-base md:text-lg text-bone-200 leading-snug">
          {t.members.countSuffix}
        </div>
      </div>

      <!-- confidentiality note + framed mark — 7 columns -->
      <aside class="lg:col-span-7 lg:pl-10 reveal" style="--reveal-delay: 160ms;">
        <div class="grid sm:grid-cols-[1fr_auto] gap-8 items-start">
          <div>
            <p class="text-[0.65rem] tracking-[0.28em] uppercase text-gold-500 mb-4">
              {lang === 'uk' ? 'Конфіденційність' : 'Confidentiality'}
            </p>
            <p class="font-display italic text-bone-100 text-xl md:text-2xl leading-snug max-w-md">
              {t.members.confidentiality}
            </p>
            <div class="mt-8 flex items-center gap-4">
              <span class="block w-10 h-px bg-gold-500"></span>
              <span class="text-[0.6rem] tracking-[0.28em] uppercase text-bone-400">
                {lang === 'uk' ? 'Внутрішній реєстр АОК' : 'AOK internal register'}
              </span>
            </div>
          </div>

          <div class="hidden sm:block">
            <div class="aspect-square w-32 md:w-40 bg-bone-100 p-4 border border-gold-600 flex items-center justify-center" aria-hidden="true">
              <img src={`${import.meta.env.BASE_URL}aok-emblem.png`} alt="" width="472" height="553" class="w-full h-full object-contain" loading="lazy" />
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>
