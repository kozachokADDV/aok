---
import { ui, type Lang } from '~/i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = ui[lang];
---
<section id="about" class="py-24 md:py-32 relative">
  <div class="container-x">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
      <div class="lg:col-span-5 reveal">
        <p class="eyebrow">{t.about.eyebrow}</p>
        <h2 class="mt-6 text-[clamp(2rem,4.5vw,3.75rem)] leading-[1.05]">
          {t.about.headline}
        </h2>
      </div>
      <div class="lg:col-span-7 lg:pt-4">
        <p class="reveal text-lg md:text-xl font-display italic text-bone-100 leading-snug" style="--reveal-delay: 80ms;">
          {t.about.intro}
        </p>
        <div class="mt-8 space-y-5 text-bone-300 leading-relaxed reveal" style="--reveal-delay: 200ms; text-align: justify; hyphens: auto; -webkit-hyphens: auto;">
          {t.about.body.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </div>

    <div class="mt-20 rule-gold"></div>

    <div class="mt-16 grid md:grid-cols-3 gap-8">
      {t.about.pillars.map((pillar, i) => (
        <div class="reveal" style={`--reveal-delay: ${i * 120}ms`}>
          <div class="flex items-baseline gap-3">
            <span class="display-num text-3xl">0{i + 1}</span>
            <span class="block flex-1 h-px bg-ink-600"></span>
          </div>
          <h3 class="mt-5 text-xl text-bone-100">{pillar.label}</h3>
          <p class="mt-3 text-sm text-bone-300 leading-relaxed">{pillar.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
