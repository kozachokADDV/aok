---
interface Props {
  size?: number;
  withText?: boolean;
  textLang?: 'uk' | 'en';
  variant?: 'plate' | 'bare';
  class?: string;
}
const {
  size = 44,
  withText = false,
  textLang = 'uk',
  variant = 'plate',
  class: cls = '',
} = Astro.props;

const textTop = textLang === 'uk' ? 'АОК' : 'SCAU';
const textBottom = textLang === 'uk'
  ? 'Асоціація Охоронних Компаній'
  : 'Security Companies Association';

const base = import.meta.env.BASE_URL;
const emblemSrc = `${base}aok-emblem.png`;
---
<div class={`flex items-center gap-3 ${cls}`}>
  {variant === 'plate' ? (
    <div
      class="emblem-plate shrink-0"
      style={`--emblem-size: ${size}px;`}
      aria-hidden="true"
    >
      <img src={emblemSrc} alt="" width="472" height="553" loading="eager" decoding="async" />
    </div>
  ) : (
    <img
      src={emblemSrc}
      alt=""
      width={size}
      height={Math.round(size * 553 / 472)}
      class="shrink-0"
      style={`width: ${size}px; height: auto;`}
      loading="eager"
      decoding="async"
      aria-hidden="true"
    />
  )}
  {withText && (
    <div class="flex flex-col leading-tight">
      <span
        class="font-display text-lg tracking-tight text-bone-100"
        style="letter-spacing: 0.08em;"
      >{textTop}</span>
      <span class="text-[0.625rem] uppercase tracking-[0.18em] text-bone-400">{textBottom}</span>
    </div>
  )}
</div>

<style>
  .emblem-plate {
    width: var(--emblem-size);
    height: var(--emblem-size);
    background: var(--color-bone-100);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: calc(var(--emblem-size) * 0.08);
    border: 1px solid var(--color-gold-600);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.04) inset, 0 8px 24px -8px rgba(0, 0, 0, 0.5);
    position: relative;
  }
  .emblem-plate img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
</style>
