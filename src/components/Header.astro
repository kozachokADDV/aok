---
import Logomark from '~/components/Logomark.astro';
import LangSwitcher from '~/components/LangSwitcher.astro';
import { ui, type Lang } from '~/i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = ui[lang];
const navItems = [
  { href: '#about', label: t.nav.about },
  { href: '#directions', label: t.nav.directions },
  { href: '#members', label: t.nav.members },
  { href: '#role', label: t.nav.role },
  { href: '#contacts', label: t.nav.contacts },
];
const mailto = `mailto:${t.contacts.email}?subject=${t.join.mailSubject}&body=${t.join.mailBody}`;
---
<header class="fixed top-0 inset-x-0 z-50 backdrop-blur-md bg-ink-950/65 border-b border-ink-700/60">
  <div class="container-x flex items-center gap-6 h-16 md:h-20">
    <a href={import.meta.env.BASE_URL + (lang === 'uk' ? '' : 'en/')} class="group" aria-label="АОК">
      <Logomark size={36} withText={true} textLang={lang} />
    </a>

    <nav class="hidden lg:flex items-center gap-8 ml-auto" aria-label="primary">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-[0.78rem] tracking-[0.18em] uppercase text-bone-300 hover:text-gold-500 transition-colors duration-300"
        >{item.label}</a>
      ))}
    </nav>

    <div class="ml-auto lg:ml-0 flex items-center gap-3">
      <LangSwitcher lang={lang} />
      <a href={mailto} class="btn hidden md:inline-flex" data-cta="header">
        <span>{t.nav.cta}</span>
      </a>
      <button
        type="button"
        class="lg:hidden inline-flex items-center justify-center w-10 h-10 border border-ink-600 text-bone-200 hover:border-gold-600 transition-colors"
        aria-label="Menu"
        data-menu-toggle
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M3 6h18M3 12h18M3 18h18" />
        </svg>
      </button>
    </div>
  </div>

  <div data-mobile-menu class="lg:hidden hidden border-t border-ink-700/60 bg-ink-950/95">
    <nav class="container-x py-6 flex flex-col gap-5" aria-label="mobile">
      {navItems.map((item) => (
        <a href={item.href} class="text-sm tracking-[0.18em] uppercase text-bone-200 hover:text-gold-500" data-mobile-link>{item.label}</a>
      ))}
      <a href={mailto} class="btn mt-2 self-start">{t.nav.cta}</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const menu = document.querySelector<HTMLDivElement>('[data-mobile-menu]');
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-mobile-link]');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  links.forEach((l) => l.addEventListener('click', () => menu?.classList.add('hidden')));
</script>
