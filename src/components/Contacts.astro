---
import { ui, type Lang } from '~/i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = ui[lang];
const mailto = `mailto:${t.contacts.email}?subject=${t.join.mailSubject}&body=${t.join.mailBody}`;
const phoneClean = t.contacts.phone.replace(/[^+\d]/g, '');
---
<section id="contacts" class="py-24 md:py-32 bg-ink-900/40 relative">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-ink-600 to-transparent"></div>
  <div class="container-x">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
      <div class="lg:col-span-5 reveal">
        <p class="eyebrow">{t.contacts.eyebrow}</p>
        <h2 class="mt-6 text-[clamp(2rem,4.5vw,3.75rem)] leading-[1.05]">
          {t.contacts.headline}
        </h2>
      </div>

      <dl class="lg:col-span-7 grid sm:grid-cols-2 gap-x-10 gap-y-10 reveal" style="--reveal-delay: 120ms;">
        <div>
          <dt class="text-[0.65rem] tracking-[0.28em] uppercase text-bone-400 mb-3">Email</dt>
          <dd>
            <a href={mailto} class="font-display text-2xl md:text-3xl text-bone-100 hover:text-gold-500 transition-colors duration-300 break-all">
              {t.contacts.email}
            </a>
          </dd>
        </div>

        <div>
          <dt class="text-[0.65rem] tracking-[0.28em] uppercase text-bone-400 mb-3">{lang === 'uk' ? 'Телефон' : 'Phone'}</dt>
          <dd>
            <a href={`tel:${phoneClean}`} class="font-display text-2xl md:text-3xl text-bone-100 hover:text-gold-500 transition-colors duration-300">
              {t.contacts.phone}
            </a>
          </dd>
        </div>

        <div class="sm:col-span-2">
          <dt class="text-[0.65rem] tracking-[0.28em] uppercase text-bone-400 mb-3">{lang === 'uk' ? 'Адреса' : 'Address'}</dt>
          <dd class="text-bone-200">
            <span class="block text-base">{t.contacts.address}</span>
            <span class="block text-base">{t.contacts.addressLine}</span>
          </dd>
        </div>

        <div class="sm:col-span-2">
          <dt class="text-[0.65rem] tracking-[0.28em] uppercase text-bone-400 mb-3">{lang === 'uk' ? 'Соцмережі' : 'Social'}</dt>
          <dd>
            <a
              href={t.contacts.facebookUrl}
              target="_blank"
              rel="noopener noreferrer me"
              class="inline-flex items-center gap-3 group text-bone-100 hover:text-gold-500 transition-colors duration-300"
            >
              <span class="inline-flex items-center justify-center w-10 h-10 border border-ink-600 group-hover:border-gold-500 transition-colors duration-300" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M14.5 8.5h2.2V5.3h-2.7c-2 0-3.5 1.4-3.5 3.4V11H8.3v3.2H10.5V21h3.3v-6.8h2.4l.4-3.2h-2.8V9.4c0-.5.3-.9 1-.9z"/></svg>
              </span>
              <span class="font-display text-lg leading-tight">{t.contacts.facebookHandle}</span>
            </a>
          </dd>
        </div>

        <div class="sm:col-span-2 pt-4">
          <a href={mailto} class="btn" data-cta="contacts">{t.contacts.cta}</a>
        </div>
      </dl>
    </div>
  </div>
</section>
