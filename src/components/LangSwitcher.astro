---
import { ui, type Lang } from '~/i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = ui[lang];
---
<div
  class="inline-flex items-center text-[0.7rem] tracking-[0.16em] uppercase border border-ink-600"
  role="group"
  aria-label={t.langSwitch.label}
>
  <button
    type="button"
    data-lang-set="uk"
    class="lang-btn px-3 py-1.5 transition-colors duration-200 text-bone-300 hover:text-gold-500"
  >{t.langSwitch.uk}</button>
  <button
    type="button"
    data-lang-set="en"
    class="lang-btn px-3 py-1.5 transition-colors duration-200 border-l border-ink-600 text-bone-300 hover:text-gold-500"
  >{t.langSwitch.en}</button>
</div>
