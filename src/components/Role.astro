---
import { ui, type Lang } from '~/i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = ui[lang];
---
<section id="role" class="py-24 md:py-32 bg-ink-900/40 relative">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-ink-600 to-transparent"></div>
  <div class="container-x">
    <header class="grid lg:grid-cols-12 gap-10 reveal">
      <div class="lg:col-span-6">
        <p class="eyebrow">{t.role.eyebrow}</p>
        <h2 class="mt-6 text-[clamp(2rem,4.5vw,3.75rem)] leading-[1.05]">
          {t.role.headline}
        </h2>
      </div>
      <p class="lg:col-span-6 text-bone-300 leading-relaxed self-end">
        {t.role.lead}
      </p>
    </header>

    <div class="mt-16 grid md:grid-cols-2 gap-px bg-ink-700">
      <div class="bg-ink-900/80 p-8 md:p-10 reveal">
        <div class="flex items-center gap-3 mb-6">
          <span class="display-num text-3xl">×</span>
          <h3 class="text-xl text-bone-100">{t.role.threats.title}</h3>
        </div>
        <ul class="space-y-3">
          {t.role.threats.items.map((it) => (
            <li class="flex items-start gap-3 text-sm text-bone-300">
              <span class="mt-2.5 w-3 h-px bg-blood-700 shrink-0"></span>
              <span>{it}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="bg-ink-900/80 p-8 md:p-10 reveal" style="--reveal-delay: 120ms;">
        <div class="flex items-center gap-3 mb-6">
          <span class="display-num text-3xl">+</span>
          <h3 class="text-xl text-bone-100">{t.role.integration.title}</h3>
        </div>
        <ul class="space-y-3">
          {t.role.integration.items.map((it) => (
            <li class="flex items-start gap-3 text-sm text-bone-300">
              <span class="mt-2.5 w-3 h-px bg-gold-500 shrink-0"></span>
              <span>{it}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <p class="mt-12 max-w-3xl text-lg md:text-xl font-display italic text-bone-100 leading-snug reveal">
      “{t.role.closing}”
    </p>
  </div>
</section>
